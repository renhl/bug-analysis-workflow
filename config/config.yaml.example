# Bug Analysis Workflow 配置模板
# 请复制此文件并修改

# ====================================
# 服务注册表（必填）
# ====================================
registry_path: config/services.yaml

# ====================================
# WeKnora 知识库（推荐）
# ====================================
weknora_base_url: http://localhost:8080/api/v1
weknora_api_key: sk-your-api-key
weknora_kb_ids:
  bug_cases: kb-00000001       # 历史 Bug 案例知识库
  business_rules: kb-00000002  # 业务规则知识库
  system_docs: kb-00000003     # 系统架构文档知识库

# ====================================
# 阿里云 SLS 日志（可选）
# ====================================
# sls_access_key: your-access-key
# sls_secret: your-secret
# sls_endpoint: cn-beijing.log.aliyuncs.com
# sls_project: your-project

# ====================================
# 数据库（可选）
# ====================================
# db_host: localhost
# db_port: 3306
# db_user: root
# db_password: your-password
# db_name: your-database

# ====================================
# 分析配置
# ====================================
confidence_threshold: 0.5      # 路由置信度阈值，低于此值会询问用户
max_related_repos: 5           # 最大关联仓库数量
enable_auto_save_case: true    # 自动保存分析结果为知识库案例